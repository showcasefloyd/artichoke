{
  "name": "jscomicdb",
  "version": "1.0.0",
  "description": "Conversion of old PHPComicDB to Angular 1.5 and Webpack",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:php": "docker compose exec -e ARTICHOKE_TEST_DB=comicdb_test -e ARTICHOKE_DB_ROOT_PASS=root backend app/vendor/bin/phpunit",
    "stack:up": "docker compose up -d --build",
    "stack:down": "docker compose down",
    "dev-server": "nodemon app/index.js",
    "dev-client": "webpack serve",
    "wp": "webpack --watch --progress",
    "wpprod": "webpack --mode production --progress"
  },
  "keywords": [
    "Comics",
    "Books",
    "JS"
  ],
  "author": "PBI",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/showcasefloyd/artichoke-comic-book-d"
  },
  "dependencies": {
    "body-parser": "~1.17.1",
    "bootstrap": "^5.3.8",
    "express": "~4.15.2",
    "jquery": "^3.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.18.0",
    "css-loader": "^6.11.0",
    "exec-php": "^0.0.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mini-css-extract-plugin": "^2.10.2",
    "node-sass": "npm:sass@^1.77.8",
    "nodemon": "^3.1.0",
    "sass": "^1.77.8",
    "sass-loader": "^14.2.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
