{
  "name": "jscomicdb",
  "version": "1.0.0",
  "description": "Conversion of old PHPComicDB to Angular 1.5 and Webpack",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run dev-server && npm run dev-client",
    "stack:up": "docker compose up -d --build",
    "stack:down": "docker compose down",
    "dev-server": "nodemon app/index.js",
    "dev-client": "node_modules/.bin/webpack-dev-server",
    "wp": "webpack --watch --progress --colors",
    "wpprod": "webpack --progress --colors -p"
  },
  "keywords": [
    "Comics",
    "Books",
    "JS"
  ],
  "author": "PBI",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/showcasefloyd/artichoke-comic-book-d"
  },
  "dependencies": {
    "angular": "^1.6.5",
    "angular-resource": "^1.6.5",
    "angular-route": "^1.6.5",
    "body-parser": "~1.17.1",
    "bootstrap": "^3.3.7",
    "bootstrap-sass": "^3.3.7",
    "express": "~4.15.2",
    "jquery": "^3.2.1"
  },
  "devDependencies": {
    "css-loader": "^0.28.4",
    "exec-php": "^0.0.5",
    "extract-text-webpack-plugin": "^2.1.2",
    "file-loader": "^0.11.2",
    "node-sass": "npm:sass@^1.77.8",
    "nodemon": "^3.1.0",
    "sass": "^1.77.8",
    "sass-loader": "^6.0.6",
    "style-loader": "^0.17.0",
    "url-loader": "^0.5.9",
    "webpack": "^2.6.1",
    "webpack-dev-server": "^2.5.0"
  }
}
